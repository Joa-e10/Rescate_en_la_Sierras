  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "ZORRO GRIS ARGENTINO\n(Lycalopex\\)\nEs un c\xE1nido nativo de Am\xE9rica
    del Sur que habita en zonas abiertas como estepas y pastizales\nMide entre 40
    y 60 cm de largo y tiene un peso de hasta 4 kg.\nPrincipalmente nocturno, y su
    dieta es omn\xEDvora.\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
